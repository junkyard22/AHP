{
  "name": "@junkyard22/mailman",
  "version": "0.1.0",
  "description": "A structured interagent messaging protocol — send validated, typed packets between roles, tools, and services in multi-agent systems.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "mailman": "dist/cli/main.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/main.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "keywords": [
    "agent",
    "multiagent",
    "messaging",
    "router",
    "ipc",
    "multimodal",
    "runtime",
    "protocol",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/junkyard22/mailman.git"
  },
  "homepage": "https://github.com/junkyard22/mailman#readme",
  "bugs": {
    "url": "https://github.com/junkyard22/mailman/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^1.6.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@types/uuid": "^9.0.0",
    "commander": "^12.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "@types/ws": "^8.5.13"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
