{
  "name": "postmaster",
  "version": "0.1.0",
  "description": "An observable message protocol and troubleshooting runtime for AI agents that checks, traces, and routes structured messages between agents, tools, and services.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "postmaster": "dist/cli/main.js",
    "mailman": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/main.js start",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["agent", "protocol", "messaging", "observability", "runtime", "multi-agent"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "uuid": "^9.0.0",
    "@types/uuid": "^9.0.0"
  }
}
